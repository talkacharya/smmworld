{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile --prefer-offline && pnpm run build:libs && pnpm --filter @workspace/smm-panel run build",
    "watchPatterns": ["artifacts/smm-panel/**", "lib/**"]
  },
  "deploy": {
    "startCommand": "npx serve dist/public --single --listen $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
